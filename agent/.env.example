# Local dev for the Track-1 agent. The judging harness injects the Fireworks
# vars and ALLOWED_MODELS itself — these are only for running it yourself.

# Local model — any OpenAI-compatible server (Ollama shown; also llama.cpp/vLLM)
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
LOCAL_MODEL=gemma2:2b

# Fireworks (remote). Use your OWN key for dev; the harness swaps it at eval.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Comma-separated; the harness publishes the real list on launch day.
ALLOWED_MODELS=accounts/fireworks/models/llama-v3p1-8b-instruct,accounts/fireworks/models/llama-v3p1-70b-instruct

# I/O contract
INPUT_PATH=/input/tasks.json
OUTPUT_PATH=/output/results.json

# Routing (tune with: python -m eval.harness --sweep)
ESCALATE_THRESHOLD=0.60
LOCAL_SAMPLES_HARD=2
REQUEST_TIMEOUT=28
