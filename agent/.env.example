# Local dev for the Track-1 agent. The judging harness injects the Fireworks
# vars and ALLOWED_MODELS itself — these are only for running it yourself.

# Fireworks (remote). Use your OWN key for dev; the harness swaps it at eval.
# Every task is answered by plain code (0 tokens) or ONE call through here.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Comma-separated; the harness publishes the real allowed list on launch day.
ALLOWED_MODELS=accounts/fireworks/models/gemma-4-31b-it
# Preferred model (used if present in ALLOWED_MODELS), plus reasoning trim.
REMOTE_MODEL=accounts/fireworks/models/gemma-4-31b-it
REASONING_EFFORT=low

# I/O contract
INPUT_PATH=/input/tasks.json
OUTPUT_PATH=/output/results.json

# Token levers
BATCH_SIZE=6
REQUEST_TIMEOUT=28
