# ── TokenOptimizer configuration ─────────────────────────────────────────────
# Copy to `.env` and edit. In mock mode you can leave everything as-is.

# mock = runs anywhere, no models/keys (dev + demo fallback)
# live = talk to a real local model (AMD/ROCm) + Fireworks AI
TOKENOPT_MODE=mock

HOST=0.0.0.0
PORT=4321

# ── Local model, served on your AMD GPU via ROCm ─────────────────────────────
# Point this at vLLM / llama.cpp / ollama exposing an OpenAI-compatible API.
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_API_KEY=EMPTY
LOCAL_MODEL=google/gemma-3-4b-it

# ── Remote frontier model (Fireworks AI) ─────────────────────────────────────
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=
REMOTE_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ── Semantic cache + router ──────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CACHE_THRESHOLD=0.90
CACHE_MAX_SIZE=2000
ROUTER_THRESHOLD=0.40

# Cosmetic label for the GPU cockpit when reading a synthesized/fallback device
GPU_LABEL=AMD Instinct MI300X
